# Copy to .env next to docker-compose.yml (do not commit real keys).
# Use with: docker compose --profile datadog --env-file .env up -d

DD_API_KEY=
DD_SITE=us5.datadoghq.com

# Enable APM export from the api service (requires datadog profile + agent running)
DD_TRACE_ENABLED=true
DD_LOGS_INJECTION=true
DD_TRACE_SAMPLE_RATE=1

# Optional unified tags
# DD_SERVICE=rt-chat-api
# DD_ENV=local
# DD_VERSION=0.0.1
