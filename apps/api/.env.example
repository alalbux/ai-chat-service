PORT=3000
DATABASE_URL=postgresql://rtchat:rtchat@localhost:5432/rtchat?schema=public

# Optional: comma-separated browser origins. If unset, reflects the request Origin (demo UI on another port).
# CORS_ORIGINS=http://127.0.0.1:3001,http://localhost:3001

# LLM_MOCK=1 uses deterministic replies (no external keys)
LLM_MOCK=1

OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-4o-mini
OPENROUTER_SITE_URL=https://localhost
OPENROUTER_APP_NAME=rt-chat-api

GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash

# Rate limit (same userId + IP keying via Throttler default; tune per deployment)
RATE_LIMIT_MAX=100
RATE_LIMIT_TTL_MS=60000
